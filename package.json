{
  "name": "sewer-fee-diagnosis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} next dev --hostname 127.0.0.1",
    "build": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma generate && DATABASE_URL=${DATABASE_URL:-file:./dev.db} next build",
    "build:worker": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/db/migrate.ts && DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma generate",
    "etl:discover": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/etl/cli.ts discover",
    "etl:download": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/etl/cli.ts download",
    "etl:import": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/etl/cli.ts import && DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/db/migrate.ts",
    "etl:statements": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/etl/importFinancialStatements.ts",
    "etl:calculate": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/etl/cli.ts calculate",
    "etl:all": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/db/migrate.ts && DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/etl/cli.ts all && DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/etl/importFinancialStatements.ts && DATABASE_URL=${DATABASE_URL:-file:./dev.db} node --import tsx scripts/db/migrate.ts",
    "gis:build": "tsx scripts/gis/build-n03-simplified.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/adapter-d1": "6.19.3",
    "@prisma/client": "^6.9.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.112.0"
  }
}
